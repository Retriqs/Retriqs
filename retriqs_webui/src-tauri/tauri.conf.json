{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Retriqs",
  "version": "0.1.0",
  "identifier": "com.retriqs.desktop",
  "build": {
    "frontendDist": "../../retriqs/api/webui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Retriqs",
        "width": 1200,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": ["backend"],
    "windows": {
      "nsis": {
        "template": "./windows/installer-template.nsi",
        "headerImage": "./windows/installer-assets/nsis-header.bmp",
        "sidebarImage": "./windows/installer-assets/nsis-sidebar.bmp",
        "installerIcon": "./windows/installer-assets/installer-icon.ico",
        "languages": ["English"],
        "customLanguageFiles": {
          "English": "./windows/nsis/English.nsh"
        }
      },
      "wix": {
        "bannerPath": "./windows/installer-assets/wix-banner.bmp",
        "dialogImagePath": "./windows/installer-assets/wix-dialog.bmp"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

